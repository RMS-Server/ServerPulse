{
  "schemaVersion": 1,
  "id": "$id",
  "version": "$version",
  "name": "ServerPulse",
  "description": "Lightweight HTTP API exposing real-time server TPS and MSPT metrics.",
  "authors": [
    "Trirrin"
  ],
  "contact": {
    "sources": "https://github.com/Trirrin/ServerPulse"
  },
  "license": "GPL-3.0",
  "icon": "assets/$id/icon.png",
  "environment": "server",
  "entrypoints": {
    "main": [
      "cn.net.rms.serverpulse.ServerPulse"
    ]
  },
  "mixins": [
    "${id}.mixins.json"
  ],
  "accessWidener": "${id}.accesswidener",
  "depends": {
    "fabricloader": ">=$loader_version",
    "minecraft": "$minecraft_version"
  }
}
